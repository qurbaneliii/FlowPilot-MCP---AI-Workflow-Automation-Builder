# FlowPilot MCP local development environment.
# Copy this file to .env before running services outside docker-compose.

APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DEBUG_PAYLOAD_LOGGING=false

# Supabase-compatible PostgreSQL connection string.
DATABASE_URL=postgresql+asyncpg://flowpilot:flowpilot@postgres:5432/flowpilot

# Static single-user scope for the MVP. Future auth can replace this value.
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# OpenAI / Agents SDK configuration.
# OPENAI_API_KEY is required for real agent calls and OpenAI API health checks.
OPENAI_API_KEY=

# Official OpenAI MCP integration. When unset, the OpenAI MCP client must start
# in documented no-op mode and log OPENAI_MCP_NOT_CONFIGURED.
OPENAI_MCP_SERVER_URL=

# GitHub MCP configuration. When unset, the GitHub client will use explicit mock mode.
GITHUB_MCP_MODE=mock
GITHUB_MCP_SERVER_URL=
GITHUB_TOKEN=

# Filesystem MCP configuration. Limit real filesystem access to this root.
FILESYSTEM_MCP_MODE=mock
FILESYSTEM_MCP_ROOT=/workspace

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
